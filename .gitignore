# 1. 新建 .gitignore（没建的话）
@"
node_modules/
dist/
*.log
.DS_Store
"@ | Out-File -Encoding utf8 .gitignore

# 2. 关键！如果之前 dist 已经被 git 追踪过，必须 untrack（参考过往踩坑经验：.gitignore 对已追踪文件无效）
git rm -r --cached dist  # 只从 git 索引移除，本地文件不删

# 3. 提交
git add .gitignore
git commit -m "add: 忽略 dist/node_modules 避免瞎推"
git push
